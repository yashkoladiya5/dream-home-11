{
  "title": "Dream Home 11 - Error Tracking",
  "uid": "dreamhome11-errors",
  "tags": ["dreamhome11", "errors", "sentry", "production"],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "constant",
        "label": "Environment",
        "query": "production",
        "current": { "text": "production", "value": "production" },
        "hide": 0
      },
      {
        "name": "interval",
        "type": "interval",
        "label": "Interval",
        "query": "5m,15m,30m,1h",
        "current": { "text": "5m", "value": "5m" },
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "title": "Sentry Error Count",
      "description": "Total Sentry events captured in the selected time range",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(increase(sentry_events_total{environment=\"$env\"}[$__range]))",
          "legendFormat": "Sentry Errors"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds",
            "fixedColor": "red"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 50, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      }
    },
    {
      "title": "Error Rate by Endpoint",
      "description": "Number of errors per endpoint over time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "topk(10, sum(rate(app_errors_by_endpoint_total{environment=\"$env\"}[$interval])) by (method, endpoint))",
          "legendFormat": "{{method}} {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "showPoints": "never",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme"
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      }
    },
    {
      "title": "Error Rate by Status Code",
      "description": "Distribution of errors by HTTP status code",
      "type": "pie-chart",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(increase(app_errors_by_status_total{environment=\"$env\"}[$__range])) by (status_code)",
          "legendFormat": "{{status_code}}",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["sum"],
          "limit": 10
        },
        "displayLabels": ["name", "percent"],
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "pie"
      }
    },
    {
      "title": "Top 10 Error Messages",
      "description": "Most frequent error messages tracked via Sentry",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "topk(10, sum(increase(sentry_events_total{environment=\"$env\"}[$__range])) by (message))",
          "legendFormat": "{{message}}",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "displayName": "Error Count"
        }
      },
      "options": {
        "sortBy": [{ "displayName": "Value", "desc": true }]
      }
    },
    {
      "title": "Errors by Type",
      "description": "Distribution of errors by error type/class",
      "type": "pie-chart",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "sum(increase(app_errors_total{environment=\"$env\"}[$__range])) by (type)",
          "legendFormat": "{{type}}",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["sum"],
          "limit": 10
        },
        "displayLabels": ["name", "percent"],
        "legend": { "displayMode": "list", "placement": "right" },
        "pieType": "pie"
      }
    },
    {
      "title": "Error Rate Trend (7-Day)",
      "description": "Daily error rate trend over the last 7 days",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(app_errors_total{environment=\"$env\"}[1d]))",
          "legendFormat": "Errors/day"
        },
        {
          "expr": "avg_over_time(sum(rate(app_errors_total{environment=\"$env\"}[1d]))[7d:1d])",
          "legendFormat": "7-day avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "showPoints": "auto",
            "lineWidth": 2,
            "fillOpacity": 15,
            "drawStyle": "line",
            "gradientMode": "scheme"
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "Response Time Distribution",
      "description": "Distribution of response times showing error vs success",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{status=~\"2..\"}[5m])) by (le))",
          "legendFormat": "P50 (Success)"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{status=~\"2..\"}[5m])) by (le))",
          "legendFormat": "P95 (Success)"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{status=~\"5..\"}[5m])) by (le))",
          "legendFormat": "P50 (5xx Error)"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{status=~\"5..\"}[5m])) by (le))",
          "legendFormat": "P95 (5xx Error)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "showPoints": "never",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "title": "5xx Error Rate",
      "description": "Percentage of 5xx errors relative to total requests",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\",environment=\"$env\"}[5m])) / sum(rate(http_requests_total{environment=\"$env\"}[5m])) * 100",
          "legendFormat": "5xx Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 10,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "title": "Error Rate by Severity",
      "description": "Breakdown of Sentry errors by severity level",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 6, "w": 9, "x": 6, "y": 24 },
      "targets": [
        {
          "expr": "sum(rate(sentry_events_total{environment=\"$env\"}[$interval])) by (level)",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "showPoints": "never",
            "stacking": { "mode": "normal" },
            "fillOpacity": 40
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "right" }
      }
    },
    {
      "title": "Endpoint Error Heatmap",
      "description": "Heatmap of errors per endpoint over time",
      "type": "heatmap",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 6, "w": 9, "x": 15, "y": 24 },
      "targets": [
        {
          "expr": "sum(rate(app_errors_by_endpoint_total{environment=\"$env\"}[$interval])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "format": "heatmap"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": { "unit": "short" },
        "color": {
          "mode": "scheme",
          "scheme": "Oranges"
        }
      }
    }
  ]
}
