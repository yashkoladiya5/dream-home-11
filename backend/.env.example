# ========================
# Dream Home 11 - Backend
# ========================
# Copy this file to .env and fill in your values
# cp .env.example .env

# App
PORT=3000
NODE_ENV=development
APP_NAME=dream-home-11

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=dream_home_11
DB_POOL_SIZE=50
DB_POOL_MIN=5
DB_IDLE_TIMEOUT=30000
DB_ACQUIRE_TIMEOUT=5000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY_DAYS=30

# Encryption (64-char hex string = 32 bytes)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# CORS
CORS_ORIGINS=https://dreamhome11.com,https://www.dreamhome11.com,https://admin.dreamhome11.com

# Payment Webhook
WEBHOOK_SECRET=

# Sentry
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# Health Check
HEALTH_SECRET=
HEALTH_CPU_THRESHOLD=85
HEALTH_MEMORY_THRESHOLD=85
HEALTH_REDIS_MEMORY_THRESHOLD=80
HEALTH_DB_POOL_THRESHOLD=80
HEALTH_CHECK_INTERVAL_MS=30000

# Rate Limiting (requests per window)
RATE_LIMIT_AUTH=5
RATE_LIMIT_CONTEST_JOIN=10
RATE_LIMIT_WALLET=10
RATE_LIMIT_KYC=5
RATE_LIMIT_API=60
RATE_LIMIT_API_KEY=100

# API Keys (comma-separated for internal services)
API_KEYS=

# Request Limits
MAX_REQUEST_SIZE_API=1048576
MAX_REQUEST_SIZE_KYC=10485760
MAX_REQUEST_SIZE_FEED=5242880
MAX_REQUEST_SIZE_AUTH=10240
MAX_STRING_LENGTH=10000

# Logging
LOG_LEVEL=debug
SLOW_REQUEST_MS=1000

# CDN
CDN_DOMAIN=cdn.dreamhome11.com

# Graceful Shutdown
GRACEFUL_SHUTDOWN_TIMEOUT=10000

# Audit
AUDIT_LOG_RETENTION_DAYS=90

# Firebase (optional — for local dev without real credentials)
FIREBASE_SERVICE_ACCOUNT_PATH=
ENABLE_MOCK_AUTH=true
